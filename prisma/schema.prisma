// Ráp Kèo — Prisma schema (theo docs/ERD.md)
// DB: PostgreSQL + PostGIS. Cột `location` dùng geography(Point, 4326).
// Prisma chưa hỗ trợ kiểu geography -> dùng Unsupported(); query "gần" bằng raw SQL (ST_DWithin/ST_Distance).

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // Image postgis/postgis tự bật sẵn các extension này; khai báo đủ để Prisma không báo drift.
  // App chỉ thực sự dùng `postgis` (geography + ST_DWithin/ST_Distance).
  extensions = [postgis, postgis_topology, postgis_tiger_geocoder, fuzzystrmatch]
}

// ---------- Enums ----------

// Thang trình độ phủi, thứ tự từ yếu -> mạnh.
enum SkillTier {
  VERY_WEAK // Siêu Yếu
  WEAK // Yếu
  BELOW_AVERAGE // Trung Bình Yếu
  AVERAGE // Trung Bình
  ABOVE_AVERAGE // Trung Bình Khá
  GOOD // Khá
  STRONG // Mạnh
}

// skill_tier của Match: như SkillTier + ANY (lọc mọi trình độ)
enum MatchSkillTier {
  VERY_WEAK
  WEAK
  BELOW_AVERAGE
  AVERAGE
  ABOVE_AVERAGE
  GOOD
  STRONG
  ANY
}

enum FieldType {
  F5
  F7
  F11
}

enum TeamRole {
  OWNER
  MEMBER
}

enum MatchType {
  FIND_OPPONENT
  NEED_PLAYERS
  FIELD_AVAILABLE
  LOOKING_FOR_TEAM
}

enum MatchStatus {
  OPEN
  MATCHED
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum NotificationType {
  MATCH_REQUEST
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  MATCH_CONFIRMED
}

// Vai trò user. ADMIN: có quyền tạo kèo từ text (AI parse) + các thao tác admin khác.
enum UserRole {
  USER
  ADMIN
}

// ---------- Models ----------

model User {
  id        String   @id @default(uuid()) @db.Uuid
  // Đăng nhập đa phương thức: user có thể có phone, email hoặc cả hai.
  phone     String?  @unique
  email     String?  @unique
  // Hash (bcrypt) cho user đăng nhập thủ công bằng SĐT + mật khẩu.
  // Nullable: user đăng nhập bằng Google không có mật khẩu.
  passwordHash String? @map("password_hash")
  // name nullable: cho user nhập sau khi đăng nhập lần đầu (onboarding).
  name      String?
  avatarUrl String?  @map("avatar_url")
  // Vai trò: USER mặc định; ADMIN có quyền parse text tạo kèo + quản trị.
  role      UserRole @default(USER) @map("role")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NextAuth OAuth: mỗi user có thể có nhiều Account (Google, ...).
  accounts        Account[]

  ownedTeams      Team[]         @relation("TeamOwner")
  teamMemberships TeamMember[]
  ownedFields     Field[]
  createdMatches  Match[]
  matchRequests   MatchRequest[]
  notifications   Notification[]

  @@map("users")
}

// Lưu token OAuth (Google) — schema chuẩn của NextAuth adapter.
// Cho phép link account OAuth vào user đã có (cùng email) và đăng nhập lại sau.
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Team {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String    @map("owner_id") @db.Uuid
  skillTier SkillTier @map("skill_tier")
  homeArea  String?   @map("home_area")
  // geography(Point, 4326) — gán/đọc qua raw SQL
  location  Unsupported("geography(Point, 4326)")?
  logoUrl   String?   @map("logo_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  owner            User           @relation("TeamOwner", fields: [ownerId], references: [id])
  members          TeamMember[]
  matches          Match[]
  requestsFromTeam MatchRequest[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Field {
  id         String                                @id @default(uuid()) @db.Uuid
  name       String
  address    String
  location   Unsupported("geography(Point, 4326)")
  fieldTypes FieldType[]                           @map("field_types")
  ownerId    String?                               @map("owner_id") @db.Uuid
  phone      String?
  createdAt  DateTime                              @default(now()) @map("created_at")
  updatedAt  DateTime                              @updatedAt @map("updated_at")

  owner   User?   @relation(fields: [ownerId], references: [id])
  matches Match[]

  @@map("fields")
}

model Match {
  id          String                                 @id @default(uuid()) @db.Uuid
  creatorId   String                                 @map("creator_id") @db.Uuid
  teamId      String?                                @map("team_id") @db.Uuid
  matchType   MatchType                              @map("match_type")
  fieldType   FieldType                              @map("field_type")
  // Mảng trình độ: kèo có thể mở cho nhiều trình độ cùng lúc (vd Khá + Mạnh).
  skillTiers  MatchSkillTier[]                       @map("skill_tiers")
  fieldId     String?                                @map("field_id") @db.Uuid
  area        String?
  location    Unsupported("geography(Point, 4326)")?
  // Mảng giờ đá: 1 kèo có thể mở nhiều giờ trong ngày (vd 18h30 + 20h30).
  playTimes   DateTime[]                             @map("play_times")
  note        String?
  status      MatchStatus                            @default(OPEN)
  createdAt   DateTime                               @default(now()) @map("created_at")
  updatedAt   DateTime                               @updatedAt @map("updated_at")

  creator  User           @relation(fields: [creatorId], references: [id])
  team     Team?          @relation(fields: [teamId], references: [id])
  field    Field?         @relation(fields: [fieldId], references: [id])
  requests MatchRequest[]

  @@index([creatorId])
  @@index([teamId])
  @@index([fieldId])
  // lọc kèo OPEN có giờ sắp tới: query lọc trong app (array không dùng B-tree trực tiếp).
  @@map("matches")
}

model MatchRequest {
  id              String             @id @default(uuid()) @db.Uuid
  matchId         String             @map("match_id") @db.Uuid
  requesterId     String             @map("requester_id") @db.Uuid
  requesterTeamId String?            @map("requester_team_id") @db.Uuid
  status          MatchRequestStatus @default(PENDING)
  message         String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  match         Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  requester     User  @relation(fields: [requesterId], references: [id])
  requesterTeam Team? @relation(fields: [requesterTeamId], references: [id])

  @@index([matchId])
  @@index([requesterId])
  @@map("match_requests")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  payload   Json
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
