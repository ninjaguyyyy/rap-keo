// Ráp Kèo — Prisma schema (theo docs/ERD.md)
// DB: PostgreSQL + PostGIS. Cột `location` dùng geography(Point, 4326).
// Prisma chưa hỗ trợ kiểu geography -> dùng Unsupported(); query "gần" bằng raw SQL (ST_DWithin/ST_Distance).

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // Connection URLs (DATABASE_URL runtime, DIRECT_URL migrate) cấu hình trong
  // prisma.config.ts (Prisma 7: datasource không còn hỗ trợ url/directUrl trực tiếp).
  // App dùng `postgis` (geography + ST_DWithin/ST_Distance).
  extensions = [postgis, postgis_topology, postgis_tiger_geocoder, fuzzystrmatch]
}

// ---------- Enums ----------

// Thang trình độ phủi, thứ tự từ yếu -> mạnh.
enum SkillTier {
  VERY_WEAK // Siêu Yếu
  WEAK // Yếu
  BELOW_AVERAGE // Trung Bình Yếu
  AVERAGE // Trung Bình
  ABOVE_AVERAGE // Trung Bình Khá
  GOOD // Khá
  STRONG // Mạnh
}

// skill_tier của Match: như SkillTier + ANY (lọc mọi trình độ)
enum MatchSkillTier {
  VERY_WEAK
  WEAK
  BELOW_AVERAGE
  AVERAGE
  ABOVE_AVERAGE
  GOOD
  STRONG
  ANY
}

enum FieldType {
  F5
  F7
  F11
}

enum TeamRole {
  OWNER
  MEMBER
}

enum MatchType {
  FIND_OPPONENT
  NEED_PLAYERS
  FIELD_AVAILABLE
  LOOKING_FOR_TEAM
  // Trận nội bộ team tự tạo (A vs B, không đối thủ ngoài, không lên /matches).
  INTERNAL
}

enum MatchStatus {
  OPEN
  MATCHED
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum NotificationType {
  MATCH_REQUEST
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  MATCH_CONFIRMED
}

// Vai trò user. ADMIN: có quyền tạo kèo từ text (AI parse) + các thao tác admin khác.
enum UserRole {
  USER
  ADMIN
}

// ---------- Models ----------

model User {
  id        String   @id @default(uuid()) @db.Uuid
  // Đăng nhập đa phương thức: user có thể có phone, email hoặc cả hai.
  phone     String?  @unique
  email     String?  @unique
  // Hash (bcrypt) cho user đăng nhập thủ công bằng SĐT + mật khẩu.
  // Nullable: user đăng nhập bằng Google không có mật khẩu.
  passwordHash String? @map("password_hash")
  // name nullable: cho user nhập sau khi đăng nhập lần đầu (onboarding).
  name      String?
  avatarUrl String?  @map("avatar_url")
  // Vai trò: USER mặc định; ADMIN có quyền parse text tạo kèo + quản trị.
  role      UserRole @default(USER) @map("role")
  // Guest = thành viên thêm bằng tên (không có tài khoản / không đăng nhập được).
  // name-only, phone/email/passwordHash null. Sau này đăng ký SĐT -> upgrade thành
  // user thật, giữ nguyên membership + stats.
  isGuest   Boolean  @default(false) @map("is_guest")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NextAuth OAuth: mỗi user có thể có nhiều Account (Google, ...).
  accounts        Account[]

  ownedTeams      Team[]         @relation("TeamOwner")
  teamMemberships TeamMember[]
  ownedFields     Field[]
  createdMatches  Match[]
  matchRequests   MatchRequest[]
  notifications   Notification[]
  // Vua phá lưới / kiến tạo: mỗi user có nhiều dòng PlayerStat (1 trận / 1 đội).
  playerStats     PlayerStat[]

  @@map("users")
}

// Lưu token OAuth (Google) — schema chuẩn của NextAuth adapter.
// Cho phép link account OAuth vào user đã có (cùng email) và đăng nhập lại sau.
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Team {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String    @map("owner_id") @db.Uuid
  skillTier SkillTier @map("skill_tier")
  homeArea  String?   @map("home_area")
  // geography(Point, 4326) — gán/đọc qua raw SQL
  location  Unsupported("geography(Point, 4326)")?
  logoUrl   String?   @map("logo_url")
  // Ảnh bìa đội (URL public từ Supabase Storage bucket team-assets). Nullable: mặc định.
  coverUrl  String?   @map("cover_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  owner            User           @relation("TeamOwner", fields: [ownerId], references: [id])
  members          TeamMember[]
  matches          Match[]
  requestsFromTeam MatchRequest[]
  // Bảng PlayerStat của đội (per-match, per-player) -> aggregate leaderboard.
  playerStats      PlayerStat[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Field {
  id         String                                @id @default(uuid()) @db.Uuid
  name       String
  address    String
  location   Unsupported("geography(Point, 4326)")
  fieldTypes FieldType[]                           @map("field_types")
  ownerId    String?                               @map("owner_id") @db.Uuid
  phone      String?
  createdAt  DateTime                              @default(now()) @map("created_at")
  updatedAt  DateTime                              @updatedAt @map("updated_at")

  owner   User?   @relation(fields: [ownerId], references: [id])
  matches Match[]

  @@map("fields")
}

model Match {
  id          String                                 @id @default(uuid()) @db.Uuid
  creatorId   String                                 @map("creator_id") @db.Uuid
  teamId      String?                                @map("team_id") @db.Uuid
  matchType   MatchType                              @map("match_type")
  fieldType   FieldType                              @map("field_type")
  // Mảng trình độ: kèo có thể mở cho nhiều trình độ cùng lúc (vd Khá + Mạnh).
  skillTiers  MatchSkillTier[]                       @map("skill_tiers")
  fieldId     String?                                @map("field_id") @db.Uuid
  area        String?
  location    Unsupported("geography(Point, 4326)")?
  // Mảng giờ đá: 1 kèo có thể mở nhiều giờ trong ngày (vd 18h30 + 20h30).
  playTimes   DateTime[]                             @map("play_times")
  note        String?
  status      MatchStatus                            @default(OPEN)
  // Tỷ số trận (ghi khi trận COMPLETED). home = đội tạo/đại diện kèo (teamId),
  // away = đội khách (resolve từ request ACCEPTED). Nullable: chưa đá / chưa chốt.
  homeScore   Int?                                   @map("home_score")
  awayScore   Int?                                   @map("away_score")
  // Trận team tự tạo (matchType FIND_OPPONENT từ team detail): tên đối thủ nhập tay
  // (chưa có team thật). Nullable: chỉ dùng cho trận do team tạo có đối thủ tự do.
  opponentName String?                               @map("opponent_name")
  // Trận nội bộ (matchType INTERNAL): tên 2 bên tự chia (vd "Đội xanh" vs "Đội đỏ").
  // home = sideA, away = sideB. Nullable: chỉ dùng cho INTERNAL.
  sideAName   String?                               @map("side_a_name")
  sideBName   String?                               @map("side_b_name")
  // true = trận do team tự tạo, KHÔNG hiện trên bảng kèo công khai /matches.
  // false (mặc định) = kèo public (flow tạo kèo cũ).
  isPrivate   Boolean  @default(false)              @map("is_private")
  createdAt   DateTime                               @default(now()) @map("created_at")
  updatedAt   DateTime                               @updatedAt @map("updated_at")

  creator  User           @relation(fields: [creatorId], references: [id])
  team     Team?          @relation(fields: [teamId], references: [id])
  field    Field?         @relation(fields: [fieldId], references: [id])
  requests MatchRequest[]
  // Bàn thắng / kiến tạo của từng cầu thủ trong trận (ghi khi COMPLETED).
  playerStats PlayerStat[]

  @@index([creatorId])
  @@index([teamId])
  @@index([fieldId])
  // lọc kèo OPEN có giờ sắp tới: query lọc trong app (array không dùng B-tree trực tiếp).
  @@map("matches")
}

model MatchRequest {
  id              String             @id @default(uuid()) @db.Uuid
  matchId         String             @map("match_id") @db.Uuid
  requesterId     String             @map("requester_id") @db.Uuid
  requesterTeamId String?            @map("requester_team_id") @db.Uuid
  status          MatchRequestStatus @default(PENDING)
  message         String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  match         Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  requester     User  @relation(fields: [requesterId], references: [id])
  requesterTeam Team? @relation(fields: [requesterTeamId], references: [id])

  @@index([matchId])
  @@index([requesterId])
  @@map("match_requests")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  payload   Json
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// Số liệu cầu thủ trong 1 trận: bàn thắng / kiến tạo. Per-match, per-team, per-player.
// Khóa (matchId, userId): 1 cầu thủ 1 dòng/trận. teamId = đội mà cầu thủ ghi bàn
// (denormalize từ membership tại thời điểm ghi) -> aggregate leaderboard theo team.
// Cascade theo match (xóa trận -> xóa stat); user/team xóa -> cascade stat.
model PlayerStat {
  id      String @id @default(uuid()) @db.Uuid
  matchId String @map("match_id") @db.Uuid
  teamId  String @map("team_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid
  goals   Int    @default(0)
  assists Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("player_stats")
}
