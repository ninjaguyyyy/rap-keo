# Database — Supabase Postgres (free). Lấy tại Dashboard > Project > Connect.
# DATABASE_URL: pooler transaction-mode (port 6543, pgbouncer=true) cho runtime app.
#   Dùng cho serverless (Vercel) — connection ngắn, prepared statements tắt qua pgbouncer.
# DIRECT_URL: pooler session-mode (port 5432) cho `prisma migrate deploy`.
#   Migrate cần session dài + advisory lock — KHÔNG dùng pooler transaction-mode.
# Dạng (thay <PROJECT-REF> + <PASSWORD>):
#   DATABASE_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
DATABASE_URL=""
DIRECT_URL=""
# Shadow DB chỉ cần khi chạy `prisma migrate dev` (tạo migration mới). Supabase free
# KHÔNG cho tạo 2 DB free -> tạo DB `postgres_shadow` trong cùng project bằng SQL
# Editor: CREATE DATABASE postgres_shadow; (có thể fail trên free plan — khi đó
# tạo migration local bằng docker compose). Bỏ trống nếu không tạo migration mới.
SHADOW_DATABASE_URL=""

# NextAuth v5 (Auth.js) — sinh bằng: npx auth secret
AUTH_SECRET=""

# Auth URL — URL public của app. Local: http://localhost:3000. Prod: https://<vercel-domain>
AUTH_URL="http://localhost:3000"

# Google OAuth — lấy tại Google Cloud Console > APIs & Services > Credentials
# > Create OAuth client ID > Web application.
# Authorized redirect URI thêm cả local + prod:
#   http://localhost:3000/api/auth/callback/google
#   https://<vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Google Gemini — admin AI parse text -> match. Lấy key tại https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7

# OTP: dev mode log ra console (chưa tích hợp provider SMS thật)
OTP_DEV_MODE="true"

# Supabase Storage (server-only, KHÔNG NEXT_PUBLIC_). Dùng cho upload ảnh bìa đội
# (bucket team-assets, public). service_role = admin toàn quyền (bypass RLS),
# CHỈ dùng phía server. Lấy tại Dashboard > Settings > API.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Tên bucket (tạo public bucket trên Dashboard > Storage trước khi dùng).
SUPABASE_TEAM_BUCKET="team-assets"

