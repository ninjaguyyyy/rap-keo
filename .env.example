# Database
DATABASE_URL="postgresql://rapkeo:rapkeo@localhost:5433/rapkeo?schema=public"
# Shadow DB cho `prisma migrate dev` (diff migrations). Local: cùng host, DB khác tên.
SHADOW_DATABASE_URL="postgresql://rapkeo:rapkeo@localhost:5433/rapkeo_shadow?schema=public"

# NextAuth v5 (Auth.js) — sinh bằng: npx auth secret
AUTH_SECRET=""

# Google OAuth — lấy tại Google Cloud Console > APIs & Services > Credentials
# > Create OAuth client ID > Web application.
# Authorized redirect URI thêm: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Google Gemini — admin AI parse text -> match. Lấy key tại https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7
