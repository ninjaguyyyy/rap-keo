# Database
DATABASE_URL="postgresql://rapkeo:rapkeo@localhost:5433/rapkeo?schema=public"

# NextAuth v5 (Auth.js) — sinh bằng: npx auth secret
AUTH_SECRET=""

# OTP: "true" = dev mode (log OTP ra console). Đặt "false" + tích hợp provider SMS khi lên prod.
OTP_DEV_MODE="true"

# Google Gemini — admin AI parse text -> match. Lấy key tại https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7
